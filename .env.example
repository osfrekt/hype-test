# Anthropic API key for Claude Haiku (research engine)
ANTHROPIC_API_KEY=your-api-key-here

# Supabase — get these from your project's Settings > API page
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Magic link JWT secret (required — do NOT reuse other keys)
MAGIC_LINK_SECRET=your-magic-link-secret-here

# Vercel env vars needed:
# - ANTHROPIC_API_KEY
# - NEXT_PUBLIC_SUPABASE_URL
# - NEXT_PUBLIC_SUPABASE_ANON_KEY
# - SUPABASE_SERVICE_ROLE_KEY
# - MAGIC_LINK_SECRET
